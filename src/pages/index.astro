---
import Layout from "@/layouts/Layout.astro";
import {
  HeroSection,
  ServiceSection,
  HowItWorkSection,
  AboutSection,
  TestimonialsSection,
  OthersServicesSection,
} from "@/components/landing";

export const prerender = true;

const title = "Hemstädning Stockholm | Samma städare varje gång | Vipsa";
const description =
  "Professionell hemstädning i Stockholm. Hos Vipsa får du alltid samma certifierade städare, fullt RUT-avdrag och 100% transparens. Boka din städning idag!";
---

<Layout title={title} description={description}>
  <HeroSection />
  <ServiceSection />
  <OthersServicesSection />
  <HowItWorkSection />
  <AboutSection />
  <TestimonialsSection />
</Layout>
