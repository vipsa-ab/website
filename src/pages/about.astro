---
import Layout from "@/layouts/Layout.astro";

import {
  HeroSection,
  StorySection,
  ValuesSection,
  TeamSection,
  CtaSection,
} from "@/components/about";

export const prerender = true;

const title = "Om Oss – Din Trygga Städfirma i Stockholm | Vipsa";
const description =
  "Lär känna Vipsa – din lokala städfirma i Stockholm. Vi skapar utrymme för livet genom trygg hemstädning med småländsk noggrannhet och RUT-avdrag på fakturan.";
---

<Layout title={title} description={description}>
  <HeroSection />
  <StorySection />
  <ValuesSection />
  <!-- <TeamSection /> -->
  <CtaSection />
</Layout>
