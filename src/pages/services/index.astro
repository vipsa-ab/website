---
import Layout from "@/layouts/Layout.astro";
import {
  HeroSection,
  ServicesSection,
  PricingSection,
  FaqSection,
  CtaSection,
  OtherServicesSection,
} from "@/components/services";

export const prerender = true;

const title = "Boka Professionella Städtjänster i Stockholm | Vipsa";
const description =
  "Boka professionella städtjänster i Stockholm. Vi erbjuder trygg hemstädning, kontorsstädning och flyttstädning med kvalitetsgaranti och 50% RUT-avdrag.";
---

<Layout title={title} description={description}>
  <HeroSection />
  <ServicesSection />
  <OtherServicesSection />
  <PricingSection />
  <FaqSection />
  <CtaSection />
</Layout>
