---
import Layout from "@/layouts/Layout.astro";
import { HeroSection } from "@/components/services";

const title = "Vipsa | Tjänster";
const description =
  "Utforska våra professionella städtjänster i Stockholm. Vi erbjuder hemstädning, kontorsstädning, flyttstädning och mer – alla med full RUT-avdrag och samma certifierade städare varje gång.";
---

<Layout title={title} description={description}>
  <HeroSection />
</Layout>
