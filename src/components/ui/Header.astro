---
import { Icon } from "astro-icon/components";
import MobileMenu from "@/components/ui/MobileMenu";

const normalizePath = (path: string) => {
  return path.replace(/\/$/, "") || "/";
};

const isActive = (path: string) => {
  const currentPath = normalizePath(Astro.url.pathname);
  const targetPath = normalizePath(path);

  return currentPath === targetPath;
};
---

<header>
  <nav class="glass-nav fixed top-0 z-50 mx-auto w-full shadow-sm">
    <div class="container mx-auto flex items-center justify-between px-4 py-4">
      <a href="/" aria-label="Gå till startsidan">
        <Icon name="logo" class="h-8 w-auto" />
      </a>
      <div class="space-gap-8 hidden items-center gap-x-10 md:flex">
        <a
          class:list={[
            "border-b-2 pb-1 font-bold transition-colors",
            isActive("/")
              ? "border-secondary text-secondary"
              : "border-transparent text-neutral-600 hover:text-neutral-900",
          ]}
          href="/">Hem</a
        >
        <a
          class:list={[
            "border-b-2 pb-1 font-bold transition-colors",
            isActive("/services")
              ? "border-secondary text-secondary"
              : "border-transparent text-neutral-600 hover:text-neutral-900",
          ]}
          href="/services">Tjänster</a
        >
        <a
          class:list={[
            "border-b-2 pb-1 font-bold transition-colors",
            isActive("/about")
              ? "border-secondary text-secondary"
              : "border-transparent text-neutral-600 hover:text-neutral-900",
          ]}
          href="/about">Om Oss</a
        >
        <a
          class:list={[
            "border-b-2 pb-1 font-bold transition-colors",
            isActive("/pricing")
              ? "border-secondary text-secondary"
              : "border-transparent text-neutral-600 hover:text-neutral-900",
          ]}
          href="/pricing">Prislista</a
        >
        <a
          class:list={[
            "border-b-2 pb-1 font-bold transition-colors",
            isActive("/contact")
              ? "border-secondary text-secondary"
              : "border-transparent text-neutral-600 hover:text-neutral-900",
          ]}
          href="/contact">Kontakt</a
        >
      </div>
      <a
        href="/booking"
        class="signature-gradient hidden rounded-full px-6 py-3 font-bold text-white transition-transform hover:scale-105 md:inline-flex"
      >
        Boka Nu
      </a>
      <MobileMenu client:visible />
    </div>
  </nav>
</header>
