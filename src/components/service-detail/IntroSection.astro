---
interface Props {
  description: string;
}

const { description } = Astro.props;
---

<section class="bg-surface py-20">
  <div class="container mx-auto max-w-3xl px-4">
    <p class="text-on-surface text-xl leading-relaxed font-medium md:text-2xl">
      {description}
    </p>
    <div
      class="text-on-surface-variant mt-10 space-y-6 text-lg leading-relaxed"
    >
      <slot />
    </div>
  </div>
</section>
