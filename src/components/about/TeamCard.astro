---
import { Image } from "astro:assets";

interface Props {
  name: string;
  role: string;
  description: string;
  image: ImageMetadata;
}

const { name, role, description, image } = Astro.props;
---

<div
  class="group bg-surface-container-lowest relative rounded-xl p-4 transition-all duration-300 hover:-translate-y-2"
>
  <div class="mb-6 aspect-3/4 overflow-hidden rounded-lg">
    <Image
      alt="Elin, Team Leader"
      class="h-full w-full object-cover grayscale transition-all duration-500 group-hover:grayscale-0"
      data-alt="Professional portrait of a friendly woman in her 30s wearing a clean uniform, smiling warmly against a soft studio background"
      src={image}
    />
  </div>
  <h4 class="font-headline text-xl font-bold">{name}</h4>
  <p class="text-primary mb-2 text-sm font-medium">
    {role}
  </p>
  <p
    class="text-on-surface-variant text-sm leading-relaxed opacity-0 transition-opacity group-hover:opacity-100"
  >
    {description}
  </p>
</div>
