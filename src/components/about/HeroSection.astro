---
import { Image } from "astro:assets";

import rectangular from "@/assets/img/rectangular.webp";
---

<section class="bg-surface relative flex h-204 items-center overflow-hidden">
  <div class="absolute inset-0 z-0">
    <Image
      alt="Clean Nordic Living Room"
      class="h-full w-full scale-105 object-cover opacity-90"
      data-alt="Modern Nordic living room with minimal white furniture, natural wood floors, and large windows with soft morning sunlight filtering through"
      src={rectangular}
      loading="eager"
    />
    <div
      class="from-surface via-surface/40 absolute inset-0 bg-linear-to-r to-transparent"
    >
    </div>
  </div>
  <div class="relative z-10 container mx-auto w-full px-4">
    <div class="max-w-2xl">
      <span
        class="label-md text-primary mb-6 inline-block font-bold tracking-widest uppercase"
        >Om Vipsa</span
      >
      <h1
        class="font-headline text-on-surface mb-8 text-5xl leading-tight font-extrabold tracking-tight md:text-7xl"
      >
        Din partner för ett <span class="text-primary">renare hem</span>
      </h1>
      <p class="text-on-surface-variant mb-10 max-w-lg text-xl leading-relaxed">
        Vi skapar utrymme för livet genom att förena småländsk noggrannhet med
        modern hållbarhet i varje hörn av ditt hem.
      </p>
    </div>
  </div>
</section>
