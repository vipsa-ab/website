---
import { Image } from "astro:assets";

import nystadatHem from "@/assets/img/nystadat-hem-stockholm-hemstadning.webp";
---

<section class="bg-surface-container-low py-24" id="service-cta">
  <div class="mx-auto max-w-5xl px-8">
    <div
      class="signature-gradient relative overflow-hidden rounded-xl p-12 text-center shadow-2xl md:p-20"
    >
      <div class="absolute inset-0 opacity-10 mix-blend-overlay">
        <Image
          alt="Ljust och nystädat vardagsrum i skandinavisk stil efter professionell hemstädning i Stockholm"
          class="h-full w-full object-cover"
          title="Skinande rent hem med vår städfirma i Stockholm"
          src={nystadatHem}
        />
      </div>
      <div class="relative z-10">
        <h2 class="text-on-primary mb-6 text-3xl font-bold md:text-5xl">
          Redo för ett skinande rent hem i Stockholm?
        </h2>
        <p class="text-on-primary/90 mx-auto mb-10 max-w-2xl text-lg">
          Låt Stockholms mest pålitliga städfirma ta hand om smutsen. Boka trygg
          hemstädning eller flyttstädning med 100% nöjd-kund-garanti och 50%
          RUT-avdrag direkt på fakturan.
        </p>
        <a
          href="/booking"
          class="bg-surface-container-lowest text-primary inline-block rounded-full px-6 py-3 text-xl font-extrabold shadow-xl transition-transform hover:scale-105 md:px-12 md:py-5"
        >
          Boka din städning nu
        </a>
      </div>
    </div>
  </div>
</section>
