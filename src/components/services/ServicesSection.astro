---
import ServiceCard from "./ServiceCard.astro";
import type { ServiceCard as Service } from "@/types";

import hemstadning from "@/assets/img/professionell-hemstadning-stockholm.webp";
import flyttstadning from "@/assets/img/komplett-flyttstadning-stockholm.webp";
import storstadning from "@/assets/img/djupgaende-storstadning-stockholm.webp";
import byggstadning from "@/assets/img/byggstadning-efter-renovering-stockholm.webp";
import kontorsstadning from "@/assets/img/foretags-och-kontorsstadning-stockholm.webp";
import trappstadning from "@/assets/img/trappstadning-for-brf-stockholm.webp";

const services: Service[] = [
  {
    title: "Hemstädning",
    description:
      "Trygg och noggrann hemstädning i Stockholm. Samma städare varje gång, anpassat efter dina behov med 50% RUT-avdrag.",
    icon: "material-symbols:home",
    img: hemstadning,
    href: "/services/home-cleaning",
  },
  {
    title: "Flyttstädning",
    description:
      "Komplett flyttstädning i Stockholm med 100% besiktningsgaranti. Vi gör din gamla bostad fläckfri inför överlämningen.",
    icon: "material-symbols:local-shipping",
    img: flyttstadning,
    href: "/services/move-cleaning",
  },
  {
    title: "Storstädning",
    description:
      "Djupgående storstädning som når varje vrå. Perfekt som vårstädning eller inför högtider, givetvis med RUT-avdrag.",
    icon: "material-symbols:cleaning-services",
    img: storstadning,
    href: "/services/deep-cleaning",
  },
  {
    title: "Byggstädning",
    description:
      "Professionell byggstädning efter renovering eller nybygge. Vi avlägsnar effektivt allt byggdamm och gör bostaden inflyttningsklar.",
    icon: "material-symbols:construction",
    img: byggstadning,
    href: "/services/construction-cleaning",
  },
  {
    title: "Kontorsstädning",
    description:
      "Kontorsstädning och företagsstädning i Stockholm som skapar en ren, hälsosam och produktiv arbetsmiljö.",
    icon: "material-symbols:corporate-fare",
    img: kontorsstadning,
    href: "/services/office-cleaning",
  },
  {
    title: "Trappstädning",
    description:
      "Noggrann trappstädning för BRF:er och fastighetsägare i Stockholm. Rena och trygga trapphus som ökar trivseln.",
    icon: "material-symbols:stairs",
    img: trappstadning,
    href: "/services/stairs-cleaning",
  },
];
---

<section class="bg-surface-container-low py-24">
  <div class="mx-auto max-w-7xl px-8">
    <div class="mb-16 text-center">
      <h2 class="mb-4 text-4xl font-bold tracking-tight">
        Våra Städtjänster i Stockholm
      </h2>
      <div class="gradient-primary mx-auto h-1.5 w-20 rounded-full"></div>
    </div>
    <div class="grid grid-cols-1 gap-8 md:grid-cols-2 lg:grid-cols-3">
      {services.map((service) => <ServiceCard {...service} />)}
    </div>
  </div>
</section>
