---
import ServiceCard from "./ServiceCard.astro";
import type { ServiceCard as Service } from "@/types";
import rectangular from "@/assets/img/rectangular.webp";

const services: Service[] = [
  {
    title: "Hemstädning",
    description:
      "Regelbunden städning som anpassas efter ditt hem och schema. Vi skapar harmoni i din vardag.",
    icon: "material-symbols:home",
    img: rectangular,
    href: "/services/home-cleaning",
  },
  {
    title: "Flyttstädning",
    description:
      "Komplett genomgång av din gamla bostad. Vi garanterar att städningen godkänns vid besiktning.",
    icon: "material-symbols:local-shipping",
    img: rectangular,
    href: "/services/move-cleaning",
  },
  {
    title: "Storstädning",
    description:
      "En djupgående rengöring av hela hemmet. Perfekt inför högtider eller som nystart varje säsong.",
    icon: "material-symbols:cleaning-services",
    img: rectangular,
    href: "/services/deep-cleaning",
  },
  {
    title: "Byggstädning",
    description:
      "Vi tar hand om byggdamm och spill efter renovering. Vi gör ditt nya bygge inflyttningsklart.",
    icon: "material-symbols:construction",
    img: rectangular,
    href: "/services/construction-cleaning",
  },
  {
    title: "Kontorsstädning",
    description:
      "Skapa en hälsosam och produktiv arbetsmiljö. Vi städar när det passar er verksamhet bäst.",
    icon: "material-symbols:corporate-fare",
    img: rectangular,
    href: "/services/office-cleaning",
  },
  {
    title: "Trappstädning",
    description:
      "För bostadsrättsföreningar och fastighetsägare. Vi håller gemensamma utrymmen rena och trygga.",
    icon: "material-symbols:stairs",
    img: rectangular,
    href: "/services/stairs-cleaning",
  },
];
---

<section class="bg-surface-container-low py-24">
  <div class="mx-auto max-w-7xl px-8">
    <div class="mb-16 text-center">
      <h2 class="mb-4 text-4xl font-bold tracking-tight">Huvudtjänster</h2>
      <div class="gradient-primary mx-auto h-1.5 w-20 rounded-full"></div>
    </div>
    <div class="grid grid-cols-1 gap-8 md:grid-cols-2 lg:grid-cols-3">
      {services.map((service) => <ServiceCard {...service} />)}
    </div>
  </div>
</section>
