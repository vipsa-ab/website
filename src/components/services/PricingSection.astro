---
import { Icon } from "astro-icon/components";
---

<section
  class="bg-surface-container-low border-outline-variant/10 border-y py-24"
  id="prices"
>
  <div class="container mx-auto px-4">
    <div class="mb-16 text-center">
      <h2 class="mb-4 text-4xl font-bold">Priser på städning i Stockholm</h2>
      <div
        class="bg-primary/10 text-primary mb-4 inline-flex items-center gap-2 rounded-full px-4 py-1.5 text-sm font-bold"
      >
        <Icon name="material-symbols:percent-discount" class="text-base" />
        50% RUT-AVDRAG INKLUDERAT I ALLA PRISER
      </div>
      <p class="text-on-surface-variant mx-auto max-w-xl">
        Letar du efter en pålitlig städfirma i Stockholm till ett bra pris? Våra
        städtjänster debiteras med full transparens. Här ser du våra aktuella
        priser för hemstädning och flyttstädning i Stockholm efter RUT-avdrag.
      </p>
    </div>
    <div class="grid grid-cols-1 gap-12 lg:grid-cols-2">
      <div
        class="bg-surface-container-lowest rounded-2xl p-8 shadow-sm md:p-12"
      >
        <h3 class="mb-8 flex items-center gap-2 text-2xl font-bold">
          <Icon name="material-symbols:schedule" class="text-primary size-6" />
          Timpriser &amp; Abonnemang
        </h3>
        <div class="space-y-6">
          <div
            class="border-outline-variant/20 flex items-center justify-between border-b pb-4"
          >
            <div>
              <h4 class="block font-bold">Hemstädning Stockholm</h4>
              <span class="text-on-surface-variant text-xs"
                >Regelbunden städning (abonnemang)</span
              >
            </div>
            <div class="text-right">
              <span class="text-primary text-2xl font-extrabold"
                >fr. 249 kr</span
              >
              <span class="text-on-surface-variant block text-xs"
                >/tim efter RUT</span
              >
            </div>
          </div>
          <div
            class="border-outline-variant/20 flex items-center justify-between border-b pb-4"
          >
            <div>
              <h4 class="block font-bold">Stor- &amp; Byggstädning</h4>
              <span class="text-on-surface-variant text-xs"
                >För en djupare rengöring (min 4 tim)</span
              >
            </div>
            <div class="text-right">
              <span class="text-primary text-2xl font-extrabold"
                >fr. 275 kr</span
              >
              <span class="text-on-surface-variant block text-xs"
                >/tim efter RUT</span
              >
            </div>
          </div>
          <div
            class="border-outline-variant/20 flex items-center justify-between border-b pb-4"
          >
            <div>
              <h4 class="block font-bold">Tilläggstjänster</h4>
              <span class="text-on-surface-variant text-xs"
                >T.ex. fönsterputsning i Stockholm</span
              >
            </div>
            <div class="text-right">
              <span class="text-primary text-2xl font-extrabold"
                >fr. 275 kr</span
              >
              <span class="text-on-surface-variant block text-xs"
                >/tim efter RUT</span
              >
            </div>
          </div>
        </div>
      </div>
      <div
        class="bg-surface-container-lowest rounded-2xl p-8 shadow-sm md:p-12"
      >
        <h3 class="mb-8 flex items-center gap-2 text-2xl font-bold">
          <Icon name="material-symbols:payments" class="text-primary size-6" />
          Uppskattningar &amp; Företag
        </h3>
        <div class="space-y-6">
          <div
            class="border-outline-variant/20 flex items-center justify-between border-b pb-4"
          >
            <div>
              <h4 class="block font-bold">Flyttstädning Stockholm</h4>
              <span class="text-on-surface-variant text-xs"
                >Fast pris baserat på bostadens yta</span
              >
            </div>
            <div class="text-right">
              <span class="text-primary text-2xl font-extrabold"
                >fr. 2 100 kr</span
              >
              <span class="text-on-surface-variant block text-xs"
                >efter RUT</span
              >
            </div>
          </div>
          <div
            class="border-outline-variant/20 flex items-center justify-between border-b pb-4"
          >
            <div>
              <h4 class="block font-bold">Kontorsstädning Stockholm</h4>
              <span class="text-on-surface-variant text-xs"
                >Anpassade lösningar för företag</span
              >
            </div>
            <div class="text-right">
              <span class="text-primary text-2xl font-extrabold"
                >fr. 345 kr</span
              >
              <span class="text-on-surface-variant block text-xs"
                >/tim exkl. moms</span
              >
            </div>
          </div>
          <div
            class="border-outline-variant/20 flex items-center justify-between border-b pb-4"
          >
            <div>
              <h4 class="block font-bold">Trappstädning för BRF</h4>
              <span class="text-on-surface-variant text-xs"
                >Kundanpassad offert i Stockholm</span
              >
            </div>
            <div class="text-right">
              <span class="text-primary text-2xl font-extrabold">Offert</span>
              <span class="text-on-surface-variant block text-xs"
                >Baserat på yta och frekvens</span
              >
            </div>
          </div>
        </div>
      </div>
    </div>
    <p class="text-on-surface-variant mt-12 text-center text-sm italic">
      * Alla priser för privatpersoner inkluderar 50% RUT-avdrag.
      Inställelseavgift tillkommer.
      <a
        class="text-primary ml-1 font-bold underline"
        href="https://www.skatteverket.se/privat/fastigheterochbostad/rotarbeteochrutarbete"
        target="_blank"
        rel="noopener noreferrer">Läs mer om RUT här</a
      >.
    </p>
  </div>
</section>
