---
import { Icon } from "astro-icon/components";
---

<section class="bg-surface relative mt-20 overflow-hidden px-4 py-12 md:py-20">
  <div class="container mx-auto">
    <nav
      aria-label="Breadcrumb"
      class="text-on-surface-variant mb-8 flex items-center gap-2 text-sm font-medium"
    >
      <a class="hover:text-primary transition-colors" href="/">Hem</a>
      <Icon name="material-symbols:chevron-right" class="text-sm" />
      <span class="text-on-surface">Tjänster</span>
    </nav>
    <div class="text-center">
      <span
        class="label-md text-primary mb-4 block font-bold tracking-[0.15em] uppercase"
        >Din städfirma i Stockholm</span
      >
      <h1
        class="text-on-surface mb-8 text-5xl leading-[1.1] font-extrabold tracking-tight md:text-6xl lg:text-7xl"
      >
        Städtjänster i Stockholm
      </h1>
      <p
        class="text-on-surface-variant mx-auto mb-10 max-w-2xl text-lg leading-relaxed md:text-xl"
      >
        Vi erbjuder trygg hemstädning, kontorsstädning och flyttstädning med
        nordisk noggrannhet. Alltid samma städare, kvalitetsgaranti och smidigt
        RUT-avdrag direkt på fakturan.
      </p>
      <div class="flex justify-center gap-4">
        <a
          href="/booking"
          class="signature-gradient text-on-primary shadow-primary/20 rounded-full px-8 py-4 font-bold shadow-xl transition-transform hover:scale-105"
        >
          Boka städning
        </a>
        <a
          class="bg-surface-container-lowest text-primary hover:bg-surface-container rounded-full px-8 py-4 font-bold transition-colors"
          href="/pricing"
        >
          Prisöversikt
        </a>
      </div>
    </div>
  </div>
</section>
