---
import { Icon } from "astro-icon/components";
---

<section class="bg-surface py-32">
  <div class="container mx-auto px-4">
    <h2 class="font-headline mb-16 text-center text-4xl font-bold">
      Priser för övriga tjänster
    </h2>
    <div class="grid grid-cols-1 gap-8 md:grid-cols-2">
      <!-- Flyttstädning -->
      <div
        class="bg-surface-container-lowest hover:border-primary-container/20 rounded-xl border border-transparent p-8 transition-all duration-300 hover:-translate-y-2"
      >
        <div
          class="bg-primary-fixed mb-8 flex h-14 w-14 items-center justify-center rounded-xl"
        >
          <Icon
            name="material-symbols:local-shipping"
            class="text-primary text-3xl"
          />
        </div>
        <h3 class="mb-4 text-2xl font-bold">Flyttstädning</h3>
        <p class="text-on-surface-variant mb-8">
          Komplett städning med garanti för att din flytt ska bli så smidig som
          möjligt.
        </p>
        <div class="mt-auto">
          <p class="text-on-surface-variant text-sm">Från (efter RUT)</p>
          <p class="text-primary text-3xl font-extrabold">1 490 kr</p>
        </div>
      </div>
      <!-- Storstädning -->
      <!-- Byggstädning -->
      <div
        class="bg-surface-container-lowest hover:border-primary-container/20 rounded-xl border border-transparent p-8 transition-all duration-300 hover:-translate-y-2"
      >
        <div
          class="bg-tertiary-fixed mb-8 flex h-14 w-14 items-center justify-center rounded-xl"
        >
          <Icon
            name="material-symbols:cleaning-services"
            class="text-tertiary text-3xl"
          />
        </div>
        <h3 class="mb-4 text-2xl font-bold">Stor- &amp; Byggstädning</h3>
        <p class="text-on-surface-variant mb-8">
          Oavsett om det är en djupgående säsongsstädning eller grovstädning
          efter renovering och nybygge ser vi till att det blir kliniskt rent.
        </p>
        <div class="mt-auto">
          <p class="text-on-surface-variant text-sm">Från (efter RUT)</p>
          <p class="text-primary text-3xl font-extrabold">225 kr/tim</p>
          <p class="text-on-surface-variant mt-1 text-xs">Minst 4 timmar</p>
        </div>
      </div>
      <!-- Kontorsstädning -->
      <div
        class="bg-surface-container-lowest hover:border-primary-container/20 rounded-xl border border-transparent p-8 transition-all duration-300 hover:-translate-y-2"
      >
        <div
          class="bg-surface-container-highest mb-8 flex h-14 w-14 items-center justify-center rounded-xl"
        >
          <Icon
            name="material-symbols:apartment"
            class="text-on-surface text-3xl"
          />
        </div>
        <h3 class="mb-4 text-2xl font-bold">Kontorsstädning</h3>
        <p class="text-on-surface-variant mb-8">
          En ren arbetsmiljö ökar trivseln. Skräddarsydda lösningar för företag.
        </p>
        <div class="mt-auto">
          <p class="text-on-surface-variant text-sm">Från (exkl. moms)</p>
          <p class="text-on-surface text-3xl font-extrabold">245 kr/tim</p>
        </div>
      </div>
      <!-- Trappstädning -->
      <div
        class="bg-surface-container-lowest hover:border-primary-container/20 rounded-xl border border-transparent p-8 transition-all duration-300 hover:-translate-y-2"
      >
        <div
          class="bg-secondary-container mb-8 flex h-14 w-14 items-center justify-center rounded-xl"
        >
          <Icon
            name="material-symbols:stairs"
            class="text-secondary text-3xl"
          />
        </div>
        <h3 class="mb-4 text-2xl font-bold">Trappstädning</h3>
        <p class="text-on-surface-variant mb-8">
          Vi håller trapphus rena och välkomnande för BRF och fastighetsägare.
        </p>
        <div class="mt-auto">
          <button class="text-primary font-bold hover:underline">
            Begär offert baserat på storlek
          </button>
        </div>
      </div>
    </div>
  </div>
</section>
