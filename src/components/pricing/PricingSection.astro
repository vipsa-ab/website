---
import { Icon } from "astro-icon/components";
---

<section class="bg-surface-container px-4 py-24">
  <div class="container mx-auto">
    <div class="grid grid-cols-1 gap-8 lg:grid-cols-3">
      <!-- Hemstädning -->
      <div
        class="bg-surface-container-lowest flex h-full flex-col rounded-xl p-8 transition-all duration-500 hover:-translate-y-2"
      >
        <div class="mb-8">
          <h3 class="font-headline mb-2 text-2xl font-bold">Hemstädning</h3>
          <p class="text-on-surface-variant text-sm">
            För ett gnistrande rent hem varje vecka.
          </p>
        </div>
        <div class="mb-8">
          <span class="text-on-surface-variant text-sm">Från</span>
          <div class="flex items-baseline gap-1">
            <span class="text-primary text-4xl font-extrabold">195 kr</span>
            <span class="text-lg font-semibold">/tim</span>
          </div>
          <p class="text-on-surface-variant mt-1 text-xs">
            efter RUT-avdrag (ord. pris 390 kr)
          </p>
        </div>
        <ul class="mb-10 grow space-y-4">
          <li class="flex items-start gap-3">
            <Icon
              name="material-symbols:check-circle"
              class="text-primary-container"
            />
            <span class="text-sm">Återkommande städning</span>
          </li>
          <li class="flex items-start gap-3">
            <Icon
              name="material-symbols:check-circle"
              class="text-primary-container"
            />
            <span class="text-sm">Samma städare varje gång</span>
          </li>
          <li class="flex items-start gap-3">
            <Icon
              name="material-symbols:check-circle"
              class="text-primary-container"
            />
            <span class="text-sm">Ingen bindningstid</span>
          </li>
          <li class="flex items-start gap-3">
            <Icon
              name="material-symbols:check-circle"
              class="text-primary-container"
            />
            <span class="text-sm">Nöjd kund-garanti</span>
          </li>
        </ul>
        <button
          class="border-primary text-primary hover:bg-primary w-full rounded-full border-2 py-4 font-bold transition-all hover:text-white"
        >
          Boka Hemstäd
        </button>
      </div>
      <!-- Flyttstädning (Featured) -->
      <div
        class="relative flex h-full flex-col overflow-hidden rounded-xl bg-white p-8 shadow-[0_40px_60px_-15px_rgba(159,66,0,0.08)] transition-all duration-500 hover:-translate-y-2"
      >
        <div
          class="bg-primary absolute top-0 right-0 rounded-bl-lg px-4 py-1.5 text-[10px] font-bold tracking-wider text-white uppercase"
        >
          Mest populär
        </div>
        <div class="mb-8">
          <h3 class="font-headline mb-2 text-2xl font-bold">Flyttstädning</h3>
          <p class="text-on-surface-variant text-sm">
            Vi tar hand om allt inför din flytt.
          </p>
        </div>
        <div class="mb-8">
          <span class="text-on-surface-variant text-sm">Från</span>
          <div class="flex items-baseline gap-1">
            <span class="text-primary text-4xl font-extrabold">1 490 kr</span>
          </div>
          <p class="text-on-surface-variant mt-1 text-xs">efter RUT-avdrag</p>
        </div>
        <ul class="mb-10 grow space-y-4">
          <li class="flex items-start gap-3">
            <Icon name="material-symbols:check-circle" class="text-primary" />
            <span class="text-sm font-medium">Fönsterputs ingår alltid</span>
          </li>
          <li class="flex items-start gap-3">
            <Icon name="material-symbols:check-circle" class="text-primary" />
            <span class="text-sm font-medium"
              >Besiktningsgaranti (14 dagar)</span
            >
          </li>
          <li class="flex items-start gap-3">
            <Icon name="material-symbols:check-circle" class="text-primary" />
            <span class="text-sm font-medium">Fast pris baserat på kvm</span>
          </li>
          <li class="flex items-start gap-3">
            <Icon name="material-symbols:check-circle" class="text-primary" />
            <span class="text-sm font-medium">Grovrengöring av vitvaror</span>
          </li>
        </ul>
        <button
          class="signature-gradient w-full rounded-full py-4 font-bold text-white shadow-lg shadow-orange-500/20 transition-all hover:opacity-90"
        >
          Boka Flyttstäd
        </button>
      </div>
      <!-- Kontorsstädning -->
      <div
        class="bg-surface-container-lowest flex h-full flex-col rounded-xl p-8 transition-all duration-500 hover:-translate-y-2"
      >
        <div class="mb-8">
          <h3 class="font-headline mb-2 text-2xl font-bold">Kontorsstädning</h3>
          <p class="text-on-surface-variant text-sm">
            Professionell miljö för dina anställda.
          </p>
        </div>
        <div class="mb-8">
          <div class="flex items-baseline gap-1">
            <span class="text-primary text-3xl font-extrabold">Offert</span>
          </div>
          <p class="text-on-surface-variant mt-1 text-xs">
            Skräddarsytt för ditt företag
          </p>
        </div>
        <ul class="mb-10 grow space-y-4">
          <li class="flex items-start gap-3">
            <Icon
              name="material-symbols:check-circle"
              class="text-primary-container"
            />

            <span class="text-sm">Anpassat efter era arbetstider</span>
          </li>
          <li class="flex items-start gap-3">
            <Icon
              name="material-symbols:check-circle"
              class="text-primary-container"
            />
            <span class="text-sm">Miljöcertifierade metoder</span>
          </li>
          <li class="flex items-start gap-3">
            <Icon
              name="material-symbols:check-circle"
              class="text-primary-container"
            />
            <span class="text-sm">Flexibla avtal</span>
          </li>
        </ul>
        <button
          class="border-primary text-primary hover:bg-primary w-full rounded-full border-2 py-4 font-bold transition-all hover:text-white"
        >
          Begär Offert
        </button>
      </div>
    </div>
  </div>
</section>
