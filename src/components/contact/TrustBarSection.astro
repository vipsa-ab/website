---
import { Icon } from "astro-icon/components";
---

<section class="mx-auto mb-24 max-w-5xl px-8">
  <div
    class="bg-surface-container grid grid-cols-1 gap-8 rounded-xl px-12 py-10 shadow-sm md:grid-cols-3"
  >
    <div class="flex items-center gap-4">
      <div
        class="bg-primary-fixed text-primary flex h-12 w-12 items-center justify-center rounded-full"
      >
        <Icon name="material-symbols:bolt" class="size-6" />
      </div>
      <div>
        <p class="font-headline text-on-surface font-bold">Snabbt svar</p>
        <p class="text-on-surface-variant text-sm">Inom 24 timmar</p>
      </div>
    </div>
    <div class="flex items-center gap-4">
      <div
        class="bg-primary-fixed text-primary flex h-12 w-12 items-center justify-center rounded-full"
      >
        <Icon name="material-symbols:verified" class="size-6" />
      </div>
      <div>
        <p class="font-headline text-on-surface font-bold">
          Certifierade städare
        </p>
        <p class="text-on-surface-variant text-sm">Proffs i varje hörn</p>
      </div>
    </div>
    <div class="flex items-center gap-4">
      <div
        class="bg-primary-fixed text-primary flex h-12 w-12 items-center justify-center rounded-full"
      >
        <Icon name="material-symbols:shield" class="size-6" />
      </div>
      <div>
        <p class="font-headline text-on-surface font-bold">Ansvarsförsäkring</p>
        <p class="text-on-surface-variant text-sm">Trygghet för ditt hem</p>
      </div>
    </div>
  </div>
</section>
